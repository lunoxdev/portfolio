---
import { Image } from "astro:assets";
import data from "../data/data";
---

<section
  class="flex flex-col justify-center items-center space-y-10 mb-40"
>
  <h2 class="text-2xl sm:text-3xl">PROJECTS</h2>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
    {
      data.projects.map((info) => (
      <figure class="flex flex-col h-full">
          <Image
            src={info.img}
            alt={info.name}
            width="800"
            height="800"
            class="rounded-md w-full h-60 sm:h-40 border"
            loading="lazy"
            format="webp"
          />
          <figcaption class="font-semibold text-base text-start mt-4">
            {info.name.toUpperCase()}
          </figcaption>
          <p class="text-md text-gray-300 mt-2 flex-grow">
            {info.description}
          </p>
          <div class="flex flex-row gap-2 py-2 rounded-lg mt-2">
            {info.skills.map((skills) => (
            <Image
              src={skills.logo}
              alt={skills.logoname}
              width="32"
              height="32"
              loading="lazy"
              class="rounded-full bg-slate-800 p-1"
              format="svg"
            />
            ))}
          </div>
          <div class="flex mt-2 mb-14 hover:underline underline-offset-8">
              <a 
              href={info.url}
              target="_blank"
              rel="noreferrer noopener nofollow"
              class="text-[#4477CE]  inline-flex items-center md:mb-2 lg:mb-0">
              Explore {info.btnname}
              <svg 
              xmlns="http://www.w3.org/2000/svg" 
              width="20" 
              height="20" 
              viewBox="0 0 16 16"><path fill="#4477CE" d="M4.133 3.692A2.501 2.501 0 0 1 6.5 2h5A2.5 2.5 0 0 1 14 4.5v5c0 1.098-.708 2.03-1.692 2.367v.364c0 .335-.117.763-.392 1.116c-.289.372-.748.653-1.377.653h-5.77A2.75 2.75 0 0 1 2 11.23V5.463c0-.549.197-1.006.546-1.323c.34-.309.785-.447 1.223-.447h.364Zm-.133 1h-.23a.81.81 0 0 0-.552.188C3.1 4.987 3 5.164 3 5.462v5.769c0 .993.776 1.77 1.77 1.77h5.769c.299 0 .474-.121.588-.268a.886.886 0 0 0 .18-.502V12H6.5A2.5 2.5 0 0 1 4 9.5V4.692ZM8 6h1.293L6.646 8.646a.5.5 0 1 0 .708.708L10 6.707V8a.5.5 0 0 0 1 0V5.5a.5.5 0 0 0-.5-.5H8a.5.5 0 0 0 0 1Z"/></svg>
              </a>
          </div>
        </figure>
      ))
    }
  </div>
</section>
