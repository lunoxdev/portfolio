---
import data from "../data/data";
---

<section class="space-y-10">
  <h2 class="font-semibold text-4xl">Projects</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
    {
      data.projects.map((info) => (
        <div class="flex flex-col relative pb-20 space-y-5">
          <figure>
            <img
              src={info.img}
              alt={info.name}
              width="800"
              height="800"
              class="rounded-lg w-auto h-auto"
              loading="eager"
            />
            <figcaption class="font-semibold text-xl mt-3">
              {info.name.toUpperCase()}
            </figcaption>
          </figure>

          <p>{info.description}</p>

          <a
            href={info.url}
            target="_blank"
            rel="noreferrer nofollow"
            class="py-3 border-b-4 border-t-4 rounded-lg border-blue-600 w-full text-center hover:bg-[#061A40] hover:font-semibold absolute bottom-0"
          >
            Explore {info.name}
          </a>
        </div>
      ))
    }
  </div>
</section>
